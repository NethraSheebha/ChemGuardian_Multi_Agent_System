# Docker Compose Environment Variables Template
# Copy this file to .env.docker and customize for your deployment

# ============================================================================
# Qdrant Configuration
# ============================================================================
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ============================================================================
# Model Paths (relative to project root)
# ============================================================================
VIDEO_MODEL_PATH=models/mobilenet_v3_small
AUDIO_MODEL_PATH=models/panns_cnn14
SENSOR_MODEL_PATH=models/sensor_adapter.pth

# ============================================================================
# Performance Configuration
# ============================================================================
PROCESSING_TIMEOUT_MS=1000
QUEUE_MAX_DEPTH=100

# ============================================================================
# Adaptive Threshold Configuration
# ============================================================================
THRESHOLD_VIDEO=0.7
THRESHOLD_AUDIO=0.65
THRESHOLD_SENSOR=2.5
THRESHOLD_LEARNING_RATE=0.05

# ============================================================================
# Emergency Contact Configuration
# ============================================================================
# Contact information for high-severity incidents
EMERGENCY_CONTACT=emergency@facility.com

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Database Paths
# ============================================================================
MSDS_DATABASE_PATH=/app/data/msds_database.json
SOP_DATABASE_PATH=/app/data/sop_database.json
